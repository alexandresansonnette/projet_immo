"""## 3.6 log_prix_m2"""

df_dvf_nettoye['log_prix_m2'] = np.log1p(df_dvf_nettoye['prix_m2'])

print(f"log_prix_m2  min={df_dvf_nettoye['log_prix_m2'].min():.2f} "
