"""# SECTION 6 — PRÉPARATION DES DONNÉES POUR LES MODÈLES"""

df_model = pd.read_csv(f'{DRIVE_PATH}/df_merged_final_complet.csv')

"""## 6.1 Encodage nature_mutation"""

