"""## 9.4 Réseau de neurones"""

print("\n🧠 Réseau de neurones...")
nn_model = create_nn_model((X_train_sc.shape[1],))
nn_model.compile(optimizer=Adam(learning_rate=0.001), loss='mse', metrics=['mae'])

