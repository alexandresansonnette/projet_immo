        'colsample_bytree': uniform(0.6, 0.35),
        'reg_alpha'      : loguniform(1e-3, 1.0),
        'reg_lambda'     : loguniform(1e-3, 1.0),
    },
    n_iter=25, cv=TimeSeriesSplit(n_splits=5),
    scoring='neg_mean_squared_error', random_state=42, n_jobs=-1
)
